@model List<SocietyApp.Models.Receipt>
@using SocietyApp.Services
@{
    Layout = null; // standalone page — no sidebar/topbar
    var year = ViewBag.Year as string ?? "";
    var quarter = ViewBag.Quarter as int? ?? 0;
}
<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <title>Bulk Print - @year Q@(quarter)</title>
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
            body {
                font-family: 'Times New Roman', serif;
                background: #fff;
            }

            .receipt-page {
                width: 210mm;
                /* A4 width */
                min-height: 297mm;
                /* A4 height */
                margin: 0 auto 0;
                padding: 16mm;
                box-sizing: border-box;
                display: flex;
                flex-direction: column;
            }

            .receipt-body {
                flex: 1;
            }

            .receipt-footer-note {
                margin-top: auto;
                border-top: 1px solid #000;
                padding-top: 4px;
                text-align: center;
                font-style: italic;
                font-size: 11px;
            }

            /* Each receipt starts on a new page when printing */
            @@media print {
                .receipt-page {
                    page-break-after: always;
                    break-after: page;
                    margin: 0;
                    padding: 16mm;
                    width: 210mm;
                    height: 297mm;
                    overflow: hidden;
                }

                .receipt-page:last-child {
                    page-break-after: avoid;
                    break-after: avoid;
                }

                .no-print {
                    display: none !important;
                }

                @@page {
                    size: A4;
                    margin: 0;
                }
            }

            @@media screen {
                .receipt-page {
                    border: 1px solid #ccc;
                    box-shadow: 0 2px 8px rgba(0, 0, 0, .08);
                    margin-bottom: 32px;
                }
            }
    </style>
</head>

<body>

    <!-- Toolbar — hidden on print -->
    <div class="no-print d-flex align-items-center gap-3 px-4 py-3 border-bottom bg-light sticky-top">
        <span class="fw-semibold">Bulk Print — @year &nbsp;Q@(quarter) &nbsp;(@Model.Count receipts)</span>
        <button onclick="window.print()" class="btn btn-sm btn-primary ms-auto">
            <i class="bi bi-printer me-1"></i> Print All
        </button>
        <a href="javascript:window.close()" class="btn btn-sm btn-outline-secondary">Close</a>
    </div>

    @foreach (var receipt in Model)
    {
        var society = receipt.Society!;
        var member = receipt.Member!;

        <div class="receipt-page">
            <div class="receipt-body">
                <!-- Header -->
                <div class="text-center mb-2">
                    <h5 class="mb-0 fw-bold text-danger">@society.Name</h5>
                    <div style="font-size:11px;">(Reg. No. @society.RegistrationNumber)</div>
                    <div style="font-size:11px;font-style:italic;">@society.Address</div>
                </div>

                <hr style="border-top:2px solid #000;margin:6px 0;" />

                <!-- Receipt No + Date -->
                <div class="d-flex justify-content-between mb-2" style="font-size:12px;">
                    <span>Receipt No.: <strong class="d-none">@receipt.ReceiptNumber</strong></span>
                    <span><strong>Date: @receipt.ReceiptDate.ToString("dd-MM-yyyy")</strong></span>
                </div>

                <!-- Member + Reference -->
                <table class="table table-bordered mb-2" style="font-size:12px;">
                    <tr>
                        <td style="width:60%">
                            <div><strong>@member.Salutation. @member.Name</strong></div>
                            <div>Flat No. @member.FlatNumber</div>
                        </td>
                        <td>
                            <div style="font-size:10px;color:#6c757d;">Cheque/NEFT/IMPS Reference</div>
                            <div><strong>@(receipt.PaymentReference ?? "—")</strong></div>
                        </td>
                    </tr>
                </table>

                <!-- Amount in words -->
                <div class="mb-2" style="font-size:12px;">
                    <strong>Rupees in words:</strong> @ReceiptService.AmountToWords(receipt.TotalAmount)
                </div>

                <!-- Line Items -->
                <table class="table table-bordered mb-2" style="font-size:12px;">
                    <thead>
                        <tr class="text-center">
                            <th style="width:40px;">S.No.</th>
                            <th class="text-start">PARTICULARS</th>
                            <th style="width:80px;">AMOUNT Rs.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int sno = 1;
                        }
                        @foreach (var item in receipt.LineItems.OrderBy(l => l.Particular?.DisplayOrder))
                        {
                            <tr>
                                <td class="text-center">@sno</td>
                                <td>@item.Particular?.Name</td>
                                <td class="text-end" style="color:@(item.Amount < 0 ? "red" : "inherit")">
                                    @(item.Amount != 0 ? item.Amount.ToString("N0") : "")
                                </td>
                            </tr>
                            sno++;
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="2" class="text-end fw-bold">TOTAL</td>
                            <td class="text-end fw-bold">@receipt.TotalAmount.ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>

                @* @if (!string.IsNullOrWhiteSpace(receipt.Remarks))
                {
                    <div class="mb-2" style="font-size:11px;"><strong>Remarks:</strong> @receipt.Remarks</div>
                }

                <!-- Period -->
                <div class="d-flex align-items-center gap-2 mb-3" style="font-size:12px;">
                    <span>Received for the month of</span>
                    <span class="border px-2 py-1">@receipt.FinancialYear (Q@(receipt.Quarter))</span>
                </div> *@

                <div class="mb-3 d-flex align-items-center" style="font-size:11px;">
                    <div class="flex-col pe-2">
                        <span>Received for the month of&nbsp;</span>
                        <span class="fw-bold">@receipt.FinancialYear (Q@(receipt.Quarter))</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(receipt.Remarks))
                    {
                        <div class="border-start ps-2 flex-col"><strong>Remarks:</strong> @receipt.Remarks</div>
                    }
                </div>

                <!-- Rs Box + Signatures -->
                <div class="d-flex gap-4 align-items-start">
                    <div class="border border-2 border-dark p-2 text-center" style="min-width:100px;">
                        <div class="fw-bold" style="font-size:12px;">Rs.</div>
                        <div class="fw-bold" style="font-size:22px;">@receipt.TotalAmount.ToString("N0")</div>
                    </div>
                    <div class="flex-grow-1 text-end">
                        <div style="font-size:11px;" class="mb-4">For <strong>@society.Name</strong></div>
                        <div class="d-flex justify-content-around">
                            <div class="text-center" style="font-size:11px;">Secretary</div>
                            <div class="text-center" style="font-size:11px;">Chairman</div>
                            <div class="text-center" style="font-size:11px;">Treasurer</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="receipt-footer-note">
                Receipt Subject to the Realisation of the cheque
            </div>
        </div>
    }

</body>
</html>
