<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Society Manager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <style>
            :root { --sidebar-bg: #1a2744; --sidebar-accent: #3b82f6; }
            body { display: flex; min-height: 100vh; background: #f0f4f8; }
            .sidebar {
                width: 230px; min-height: 100vh; background: var(--sidebar-bg);
                color: #c8d3e8; padding: 0; flex-shrink: 0; position: fixed; top: 0; left: 0; bottom: 0;
            }
            .sidebar-brand { padding: 20px 16px; border-bottom: 1px solid rgba(255,255,255,0.08); }
            .sidebar-brand span { font-size: 13px; color: #8fa3c8; display: block; margin-top: 2px; }
            .sidebar .nav-link {
                color: #c8d3e8; padding: 9px 16px; font-size: 14px; border-radius: 6px;
                margin: 1px 8px; transition: all .15s;
            }
            .sidebar .nav-link:hover, .sidebar .nav-link.active {
                background: var(--sidebar-accent); color: #fff;
            }
            .sidebar .nav-link i { width: 20px; text-align: center; margin-right: 8px; }
            .sidebar-section { font-size: 10px; text-transform: uppercase; letter-spacing: .08em;
                color: #5d7099; padding: 12px 16px 4px; }
            .main-content { margin-left: 230px; flex: 1; padding: 24px; }
            .topbar { background: #fff; border-radius: 10px; padding: 12px 20px;
                margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between;
                box-shadow: 0 1px 4px rgba(0,0,0,.06); }
            .page-card { background: #fff; border-radius: 10px; padding: 24px;
                box-shadow: 0 1px 4px rgba(0,0,0,.06); }
    </style>
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar -->
        <nav class="sidebar d-flex flex-column">
            <div class="sidebar-brand">
                <div class="fw-bold text-white fs-6"><i class="bi bi-building me-2"></i>Society Manager</div>
                <span>@User.FindFirst("SocietyName")?.Value</span>
            </div>
            <div class="mt-2 flex-grow-1">
                <div class="sidebar-section">Main</div>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <div class="sidebar-section">Administration</div>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Society" ? "active" : "")"
                       asp-controller="Society" asp-action="Index">
                    <i class="bi bi-buildings"></i> Societies
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Member" ? "active" : "")"
                       asp-controller="Member" asp-action="Index">
                    <i class="bi bi-people"></i> Members
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Particular" ? "active" : "")"
                       asp-controller="Particular" asp-action="Index">
                    <i class="bi bi-list-ul"></i> Particulars
                </a>

                <div class="sidebar-section">Billing</div>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Receipt" ? "active" : "")"
                       asp-controller="Receipt" asp-action="Index">
                    <i class="bi bi-receipt"></i> Receipts
                </a>
                <a class="nav-link" asp-controller="Receipt" asp-action="Create">
                    <i class="bi bi-plus-circle"></i> New Receipt
                </a>

                <div class="sidebar-section">Reports</div>
                <a class="nav-link" asp-controller="Report" asp-action="Collection">
                    <i class="bi bi-graph-up"></i> Collection Report
                </a>
                <a class="nav-link" asp-controller="Report" asp-action="Defaulters">
                    <i class="bi bi-exclamation-triangle"></i> Defaulters
                </a>
            </div>
            <div class="p-3 border-top" style="border-color:rgba(255,255,255,0.08)!important">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-sm btn-outline-secondary w-100 text-white border-secondary">
                        <i class="bi bi-box-arrow-left me-1"></i> Logout
                    </button>
                </form>
            </div>
        </nav>
    }

    <!-- Main Content -->
    <div class="@(User.Identity?.IsAuthenticated == true ? "main-content" : "w-100")">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="topbar">
                <h5 class="mb-0 fw-semibold text-dark">@ViewData["Title"]</h5>
                <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@User.Identity.Name</span>
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
