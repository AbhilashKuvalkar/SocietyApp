@model List<SocietyApp.Models.Society>
@{
    ViewData["Title"] = "Societies";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h6 class="mb-1 fw-bold">All Societies</h6>
            <p class="text-muted small mb-0">Manage registered housing societies</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Add Society
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-buildings fs-1 d-block mb-2"></i>
            No societies found. <a asp-action="Create">Add the first one.</a>
        </div>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Society Name</th>
                    <th>Code</th>
                    <th>Reg. Number</th>
                    <th>Address</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="fw-semibold">@s.Name</td>
                        <td><span class="badge bg-secondary">@s.SocietyCode</span></td>
                        <td class="text-muted small">@s.RegistrationNumber</td>
                        <td class="text-muted small" style="max-width:220px;">@s.Address</td>
                        <td>
                            @if (s.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @s.Name? This cannot be undone.')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
