@model List<SocietyApp.Models.Member>
@{
    ViewData["Title"] = "Members";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h6 class="mb-1 fw-bold">All Members</h6>
            <p class="text-muted small mb-0">Manage flat owners and tenants</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Add Member
        </a>
    </div>

    <table class="table table-hover">
        <thead class="table-light sticky-top">
            <tr>
                <th>Flat No.</th>
                <th>Name</th>
                <th>Type</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Move-in</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td><span class="badge bg-primary">@m.FlatNumber</span></td>
                    <td>@m.Salutation. @m.Name</td>
                    <td>
                        @if (m.TenantType == SocietyApp.Models.TenantType.Permanent)
                        {
                            <span class="badge bg-success">Permanent</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Temporary</span>
                        }
                    </td>
                    <td>@(m.Phone ?? "—")</td>
                    <td>@(m.Email ?? "—")</td>
                    <td>@(m.MoveInDate.HasValue? m.MoveInDate.Value.ToString("dd MMM yyyy") : "—")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <form asp-action="Delete" asp-route-id="@m.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Delete @m.Name?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
